# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/masterdocs

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:4000

# Node environment
NODE_ENV=development

# GitHub Content Editor (optional — only needed for the MDX content editor)
#
# Create a fine-grained personal access token at:
#   https://github.com/settings/tokens?type=beta
#
# 1. Set "Repository access" to "Only select repositories" and pick your repo
# 2. Under "Repository permissions", enable:
#    - Contents:       Read and write  (read files, create/update files, branches)
#    - Pull requests:  Read and write  (create, merge, close PRs)
# 3. No account permissions are needed
#
GITHUB_TOKEN=github_pat_your_fine_grained_token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
